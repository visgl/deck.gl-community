    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test-watch": "vitest"
  },
  "peerDependencies": {
    "@deck.gl/aggregation-layers": ">=9.0.0",
    "@deck.gl/core": ">=9.0.0",
    "@deck.gl/layers": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@deck.gl/aggregation-layers": {
      "optional": true
    }
  }
