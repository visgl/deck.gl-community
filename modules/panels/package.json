{
  "name": "@deck.gl-community/panels",
  "version": "9.3.2",
  "description": "Deck-independent panel composition and standalone UI",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "panels",
    "widgets",
    "ui",
    "visualization"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "src/widget-panels/ai-assist-panel.tsx"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test-watch": "vitest"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7"
  },
  "dependencies": {
    "@openassistant/core": "0.5.20",
    "@openassistant/ui": "^0.5.20",
    "@probe.gl/stats": "^4.1.1",
    "preact": "^10.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependencies": {
    "@deck.gl/widgets": "~9.3.0"
  }
}
